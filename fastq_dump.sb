#!/bin/bash --login
#SBATCH --job-name=fastaAlternateReference
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --time=4:00:00
#SBATCH --mail-type=ALL
#SBATCH --mem=96GB 
#SBATCH --mail-user=bergcole@msu.edu
#SBATCH --output=%x-%j.SLURMout

module purge
module load GATK 

gatk FastaAlternateReferenceMaker \
  -R /mnt/gs21/scratch/bergcole/Pvirgatumvar_AP13HAP1_772_v6.0.fa \
  -O /mnt/gs21/scratch/bergcole/ASE/DAC6_alt.fasta \
  -L Chr01K \
  -L Chr02K \
  -L Chr03K \
  -L Chr04K \
  -L Chr05K \
  -L Chr06K \
  -L Chr07K \
  -L Chr08K \
  -L Chr09K \
  -L Chr01N \
  -L Chr02N \
  -L Chr03N \
  -L Chr04N \
  -L Chr05N \
  -L Chr06N \
  -L Chr07N \
  -L Chr08N \
  -L Chr09N \
  -V /mnt/gs21/scratch/bergcole/ASE/AP13_DAC6_allChroms_biallelic.recode.vcf \